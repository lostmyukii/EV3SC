# Safe checked-in defaults for local teacher-computer deployment.
# Copy to a private env file before adding a pairing token.

WEISILE_LINK_HOST=127.0.0.1
WEISILE_LINK_PORT=20111
TRAINER_WS_PORT=8766
EV3_IP=ev3dev.local
EV3_WS_PORT=8765
MAX_COLLECTED_POINTS=10000
LOG_LEVEL=INFO

# Optional values:
# EV3_BT=00:16:53:AA:BB:CC
# WEISILE_TRANSPORT=auto
# WEISILE_PAIRING_TOKEN is intentionally omitted; generate this per classroom.
