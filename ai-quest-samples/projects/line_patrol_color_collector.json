{
  "schemaVersion": "vsle-ai-quest-sample-v1",
  "id": "line-patrol-color-collector",
  "order": 2,
  "title": "Line Patrol Color Collector",
  "ageBand": "7-15",
  "goal": "Collect reflected-light readings for a line and floor classifier.",
  "estimatedMinutes": 18,
  "hardware": {
    "motors": ["A", "B"],
    "sensors": ["S1", "S3"],
    "transports": ["wifi", "bluetooth"]
  },
  "labels": ["line", "floor"],
  "workflow": [
    {
      "stage": "record",
      "title": "Record line and floor samples",
      "script": [
        {"opcode": "startDataCollection", "args": {"LABEL": "line"}},
        {"opcode": "motorSyncRun", "args": {"PORT_L": "A", "PORT_R": "B", "SPEED": 25, "TIME": 2}},
        {"opcode": "stopDataCollection", "args": {}},
        {"opcode": "startDataCollection", "args": {"LABEL": "floor"}},
        {"opcode": "motorSyncRun", "args": {"PORT_L": "A", "PORT_R": "B", "SPEED": 25, "TIME": 2}},
        {"opcode": "stopDataCollection", "args": {}}
      ]
    },
    {
      "stage": "upload",
      "title": "Upload line data to WeisileAI Trainer",
      "script": [
        {"opcode": "uploadToTrainer", "args": {}}
      ]
    },
    {
      "stage": "train",
      "title": "Train a decision tree",
      "trainerActions": ["clean-outliers", "select-features", "train-decision-tree"]
    },
    {
      "stage": "export",
      "title": "Export classroom data and model rules",
      "script": [
        {"opcode": "exportDataCSV", "args": {}}
      ]
    }
  ],
  "trainer": {
    "features": ["color_reflected", "gyro_angle", "motor_a_pos"],
    "model": {"type": "decision_tree", "accuracyGate": 0.7},
    "exportArtifacts": ["vsle_ev3_data.csv", "model_rules.json"]
  },
  "privacy": {
    "localFirst": true,
    "studentDataCollected": false,
    "deleteRoute": "/api/data/clear",
    "deletionInstructions": "Use clear session after export or at the end of class."
  }
}
